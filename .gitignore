# .gitignore for bedrock-foundation/
# Comprehensive coverage for Python, AWS, Jupyter, and OS-specific patterns

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === Virtual Environments ===
venv/
ENV/
env/
.venv

# === Jupyter Notebooks ===
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# === AWS ===
.aws/
*.pem

# === Secrets & Credentials ===
.env
.env.local
credentials.json
config.json
*.key
*.secret

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db

# === Testing ===
.pytest_cache/
.coverage
htmlcov/

# === Model Artifacts ===
*.pkl
*.h5
*.model
embeddings/
vector_store/
faiss_index/

# === Large Files ===
*.zip
*.tar.gz
*.rar

# === Logs ===
*.log
logs/
